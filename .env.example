# ── 複製這個檔案為 .env，填入真實數值 ──────────────────────
# !! .env 絕對不能上傳到 GitHub !!

# Flask Secret Key（必填）
# 產生指令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this

# Supabase PostgreSQL 連線字串（必填）
# 從 Supabase → Settings → Database → Connection String → URI 複製
DATABASE_URL=postgresql://postgres:your-password@db.xxxx.supabase.co:5432/postgres

# 開發用設定（正式部署時不需要）
FLASK_DEBUG=false
SQLALCHEMY_ECHO=false
